# Everything else under training/data/ is regenerable (prepare_dataset.py /
# train_baseline.py) and stays out of the repo.
training/data/raw/
training/data/train.parquet
training/data/val.parquet
training/data/test.parquet
training/data/baseline_holdout_preds.parquet
training/data/champion_holdout_preds.parquet
