# Raseed environment template — copy to .env to boot the default stack.
# Vault is the secret source of truth in real deployments; these local defaults
# are the documented first trim rung (constitution Art. V), never a silent prod
# default. Every value here is enough to bring the default compose profile up.

# ── App ───────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO

# ── Postgres (pgvector) ───────────────────────────
POSTGRES_USER=raseed
POSTGRES_PASSWORD=raseed_local_dev
POSTGRES_DB=raseed
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async driver DSN used by the backend (services talk by service name, not localhost)
DATABASE_URL=postgresql+asyncpg://raseed:raseed_local_dev@postgres:5432/raseed

# ── Redis (sessions + RQ) ─────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── MinIO (model artifacts ONLY) ──────────────────
MINIO_ROOT_USER=raseed
MINIO_ROOT_PASSWORD=raseed_local_dev
MINIO_ENDPOINT=minio:9000
MINIO_ARTIFACTS_BUCKET=model-artifacts

# ── Vault (dev mode this phase) ───────────────────
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN_ID=raseed_local_dev_token
VAULT_TOKEN=raseed_local_dev_token

# ── Model server ──────────────────────────────────
MODELSERVER_URL=http://modelserver:8080

# ── LLM adapter (Gemini -> Grok failover) ─────────
# Real keys resolve from Vault; left blank locally — no LLM calls in Phase 0.
GEMINI_API_KEY=
GROK_API_KEY=

# ── Frontend ──────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
